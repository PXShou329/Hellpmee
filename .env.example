# ============================================================
# 黑優浦蜜 helpmee_v2 - Environment Example
#
# Copy this file to .env and fill in your real keys.
# DO NOT commit .env, secrets/, or cookies files to GitHub.
# ============================================================


# ============================================================
# Discord Bot
# ============================================================
DISCORD_TOKEN=your_discord_bot_token_here


# ============================================================
# Utility AI Provider
# Main provider: Gemini
# Fallback provider: OpenAI
# ============================================================
UTILITY_AI_ENABLED=false

AI_PRIMARY_PROVIDER=gemini
AI_SECONDARY_PROVIDER=openai
AI_FALLBACK_ENABLED=true
AI_TIMEOUT_SECONDS=25

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

UTILITY_AI_DAILY_LIMIT=100
UTILITY_AI_PER_USER_DAILY_LIMIT=10


# ============================================================
# Google Places API
# Used for food / drink search features
# ============================================================
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here


# ============================================================
# Taiwan Weather API - CWA
# Optional. If empty, fallback weather source may be used.
# ============================================================
CWA_API_KEY=your_cwa_api_key_here


# ============================================================
# Spotify API
# Optional. Used for Spotify metadata, then search/play via YouTube.
# ============================================================
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here


# ============================================================
# FFmpeg
# Windows example:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
#
# Docker / Linux usually:
# FFMPEG_PATH=ffmpeg
# ============================================================
FFMPEG_PATH=ffmpeg


# ============================================================
# yt-dlp YouTube cookies
# Used to reduce "Sign in to confirm you're not a bot" errors on VPS.
#
# Docker container path:
# YTDLP_COOKIES_FILE=/app/secrets/youtube_cookies.txt
#
# Never commit youtube_cookies.txt or secrets/ to GitHub.
# ============================================================
YTDLP_COOKIES_FILE=/app/secrets/youtube_cookies.txt


# ============================================================
# Database
# ============================================================
DB_BACKEND=sqlite
SQLITE_PATH=helpmee.db

# PostgreSQL example:
# DB_BACKEND=postgres
# DATABASE_URL=postgresql://helpmee:password@localhost:5432/helpmee


# ============================================================
# Redis
# Optional queue/cache backend
# ============================================================
# REDIS_URL=redis://localhost:6379


# ============================================================
# Food search defaults
# ============================================================
FOOD_SEARCH_RADIUS=1000
FOOD_MAX_RESULTS=5
DEFAULT_LOCATION_LAT=25.0330
DEFAULT_LOCATION_LNG=121.5654


# ============================================================
# Music
# ============================================================
MUSIC_QUEUE_MAX=100
SPOTIFY_PLAYLIST_MAX=25


# ============================================================
# Debug
# ============================================================
DEBUG_COMMANDS_ENABLED=false
